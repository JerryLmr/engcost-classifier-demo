{
  "version": "v1.0",
  "engine_name": "maintenance_fund_audit_engine",
  "updated_at": "2026-04-02",
  "description": "维修资金审计规则引擎。标签层不直接出结果，规则引擎根据路径输出柔性结论：初步符合、疑似违规、需补充材料、建议人工复核。",

  "result_policy": {
    "internal_result_enum": [
      "compliant",
      "non_compliant",
      "need_supplement",
      "manual_review"
    ],
    "display_mapping": {
      "compliant": "初步符合",
      "non_compliant": "疑似违规",
      "need_supplement": "需补充材料",
      "manual_review": "建议人工复核"
    }
  },

  "input_schema": {
    "required_fields": [
      "project_name"
    ],
    "optional_fields": [
      "project_desc",
      "matched_object_ids",
      "normalized_tags",
      "mapping_confidence",
      "is_common_part",
      "is_common_facility",
      "is_emergency",
      "is_out_of_warranty",
      "amount",
      "has_vote",
      "has_announcement",
      "has_budget_review",
      "has_site_photos",
      "has_rectification_notice",
      "has_construction_plan",
      "has_completion_report",
      "has_invoice",
      "is_public_window",
      "location_detail",
      "damage_description",
      "repair_scope_description",
      "repair_extent",
      "is_property_service_scope",
      "is_function_restoration",
      "is_upgrade",
      "is_relocation",
      "split_projects"
    ]
  },

  "decision_flow": [
    "INPUT_CHECK",
    "CATALOG_CHECK",
    "TAG_ROUTING",
    "EXCLUSION_CHECK",
    "GRAY_CASE_ROUTING",
    "GRAY_CASE_REVIEW_CHECK",
    "EMERGENCY_CHECK",
    "NORMAL_SCOPE_CHECK",
    "PROCESS_CHECK",
    "OUTPUT_BUILD"
  ],

  "reason_code_definitions": {
    "OUTSIDE_CATALOG": "未命中对象目录",
    "INSUFFICIENT_INFO": "输入信息不足",
    "MULTI_PROJECT": "输入中包含多个不同工程",
    "GREENING_MAINTENANCE": "属于绿化养护",
    "CLEANING_SANITATION": "属于清洁卫生服务",
    "INSPECTION_TESTING": "属于检测检查",
    "NEW_CONSTRUCTION": "属于新增/加装/扩建",
    "DAILY_SERVICE": "属于物业日常服务",
    "GRAY_CASE_GENERAL": "一般灰区",
    "GRAY_CASE_MINOR_REPAIR": "零星维修灰区",
    "GRAY_CASE_UPGRADE_VS_REPAIR": "修复与升级边界不清",
    "GRAY_CASE_CONTRACT_BOUNDARY": "物业维保边界不清",
    "MISSING_GRAY_CASE_EVIDENCE": "灰区缺少关键补充材料",
    "MISSING_VOTE": "缺少表决信息",
    "MISSING_ANNOUNCEMENT": "缺少公示信息",
    "MISSING_BUDGET_REVIEW": "缺少审价材料",
    "MISSING_CONTRACT": "缺少施工合同",
    "MISSING_INVOICE": "缺少发票",
    "MISSING_COMPLETION_REPORT": "缺少完工/验收材料",
    "MISSING_EMERGENCY_DOC": "缺少紧急维修证明材料",
    "WITHIN_WARRANTY": "属于保修期内",
    "OUTSIDE_SCOPE_PRIVATE_PART": "属于专有部分",
    "OUTSIDE_SCOPE_UNKNOWN_OBJECT": "无法确认维修对象",
    "PROPERTY_SERVICE_SCOPE": "属于物业服务合同维保范围"
  },

  "rules": [
    {
      "rule_id": "INPUT_001",
      "name": "多工程输入识别",
      "stage": "INPUT_CHECK",
      "priority": 10,
      "when": {
        "any": [
          { "field": "normalized_tags", "op": "contains", "value": "multi_project" },
          { "field": "split_projects", "op": "length_gt", "value": 1 }
        ]
      },
      "then": {
        "result": "manual_review",
        "reason_codes": ["MULTI_PROJECT"],
        "message": "输入包含多个不同类型工程，建议拆分后分别审计"
      },
      "source": {
        "source_type": "system_rule",
        "title": "输入规范规则",
        "issuer": null,
        "document_no": null,
        "article": null,
        "section": null,
        "chapter": null,
        "clause_label": null,
        "public_access": false,
        "display_name": "系统输入规范规则"
      },
      "is_active": true
    },

    {
      "rule_id": "INPUT_002",
      "name": "信息不足",
      "stage": "INPUT_CHECK",
      "priority": 20,
      "when": {
        "all": [
          { "field": "project_name", "op": "empty_or_null" }
        ]
      },
      "then": {
        "result": "manual_review",
        "reason_codes": ["INSUFFICIENT_INFO"],
        "message": "缺少最基本的项目名称信息"
      },
      "source": {
        "source_type": "system_rule",
        "title": "输入规范规则",
        "issuer": null,
        "document_no": null,
        "article": null,
        "section": null,
        "chapter": null,
        "clause_label": null,
        "public_access": false,
        "display_name": "系统输入规范规则"
      },
      "is_active": true
    },

    {
      "rule_id": "CATALOG_001",
      "name": "目录外对象",
      "stage": "CATALOG_CHECK",
      "priority": 30,
      "when": {
        "all": [
          { "field": "matched_object_ids", "op": "empty_array" }
        ]
      },
      "then": {
        "result": "manual_review",
        "reason_codes": ["OUTSIDE_CATALOG"],
        "message": "未命中维修对象目录，进入一事一议"
      },
      "source": {
        "source_type": "system_rule",
        "title": "目录命中规则",
        "issuer": null,
        "document_no": null,
        "article": null,
        "section": null,
        "chapter": null,
        "clause_label": null,
        "public_access": false,
        "display_name": "目录命中规则"
      },
      "is_active": true
    },

    {
      "rule_id": "EXCLUSION_001",
      "name": "绿化养护排除",
      "stage": "EXCLUSION_CHECK",
      "priority": 40,
      "when": {
        "all": [
          { "field": "normalized_tags", "op": "contains", "value": "daily_greening" }
        ]
      },
      "then": {
        "result": "non_compliant",
        "reason_codes": ["GREENING_MAINTENANCE", "DAILY_SERVICE"],
        "message": "项目疑似属于绿化日常养护范围"
      },
      "source": {
        "source_type": "public_standard",
        "title": "住宅物业管理服务规范",
        "issuer": "上海市市场监督管理局",
        "document_no": "DB31/T 360—2020",
        "article": null,
        "section": "第8章",
        "chapter": null,
        "clause_label": null,
        "public_access": true,
        "display_name": "《住宅物业管理服务规范》（DB31/T 360—2020）第8章"
      },
      "is_active": true
    },

    {
      "rule_id": "EXCLUSION_002",
      "name": "清洁卫生排除",
      "stage": "EXCLUSION_CHECK",
      "priority": 41,
      "when": {
        "all": [
          { "field": "normalized_tags", "op": "contains", "value": "cleaning_sanitation" }
        ]
      },
      "then": {
        "result": "non_compliant",
        "reason_codes": ["CLEANING_SANITATION", "DAILY_SERVICE"],
        "message": "项目疑似属于清洁卫生服务范围"
      },
      "source": {
        "source_type": "public_standard",
        "title": "住宅物业管理服务规范",
        "issuer": "上海市市场监督管理局",
        "document_no": "DB31/T 360—2020",
        "article": null,
        "section": "第7章",
        "chapter": null,
        "clause_label": null,
        "public_access": true,
        "display_name": "《住宅物业管理服务规范》（DB31/T 360—2020）第7章"
      },
      "is_active": true
    },

    {
      "rule_id": "EXCLUSION_003",
      "name": "检测检查排除",
      "stage": "EXCLUSION_CHECK",
      "priority": 42,
      "when": {
        "all": [
          { "field": "normalized_tags", "op": "contains", "value": "inspection_testing" }
        ]
      },
      "then": {
        "result": "non_compliant",
        "reason_codes": ["INSPECTION_TESTING"],
        "message": "项目疑似属于检测、年检或试验类事项"
      },
      "source": {
        "source_type": "public_standard",
        "title": "住宅物业管理服务规范",
        "issuer": "上海市市场监督管理局",
        "document_no": "DB31/T 360—2020",
        "article": null,
        "section": "附录E 升降系统",
        "chapter": null,
        "clause_label": null,
        "public_access": true,
        "display_name": "《住宅物业管理服务规范》（DB31/T 360—2020）附录E 升降系统"
      },
      "is_active": true
    },

    {
      "rule_id": "EXCLUSION_004",
      "name": "新增建设排除",
      "stage": "EXCLUSION_CHECK",
      "priority": 43,
      "when": {
        "all": [
          { "field": "normalized_tags", "op": "contains", "value": "new_construction" }
        ]
      },
      "then": {
        "result": "non_compliant",
        "reason_codes": ["NEW_CONSTRUCTION"],
        "message": "项目疑似属于新增、加装或扩建事项"
      },
      "source": {
        "source_type": "public_regulation",
        "title": "住宅专项维修资金管理办法",
        "issuer": "中华人民共和国建设部、中华人民共和国财政部",
        "document_no": "第165号",
        "article": "第二十五条",
        "section": null,
        "chapter": null,
        "clause_label": null,
        "public_access": true,
        "display_name": "《住宅专项维修资金管理办法》（第165号）第二十五条"
      },
      "is_active": true
    },

    {
      "rule_id": "GRAY_001",
      "name": "强灰区直接人工复核",
      "stage": "GRAY_CASE_ROUTING",
      "priority": 50,
      "when": {
        "all": [
          { "field": "normalized_tags", "op": "contains", "value": "gray_case" },
          { "field": "gray_case_type", "op": "eq", "value": "strong" }
        ]
      },
      "then": {
        "result": "manual_review",
        "reason_codes": ["GRAY_CASE_GENERAL"],
        "message": "项目属于强灰区，建议人工复核"
      },
      "source": {
        "source_type": "system_rule",
        "title": "灰区分层规则",
        "issuer": null,
        "document_no": null,
        "article": null,
        "section": null,
        "chapter": null,
        "clause_label": null,
        "public_access": false,
        "display_name": "灰区分层规则"
      },
      "is_active": true
    },

    {
      "rule_id": "GRAY_002",
      "name": "弱灰区缺少消解材料",
      "stage": "GRAY_CASE_REVIEW_CHECK",
      "priority": 51,
      "when": {
        "all": [
          { "field": "normalized_tags", "op": "contains", "value": "gray_case" },
          { "field": "gray_case_type", "op": "eq", "value": "weak" },
          {
            "field": "gray_case_evidence_complete",
            "op": "eq",
            "value": false
          }
        ]
      },
      "then": {
        "result": "need_supplement",
        "reason_codes": ["MISSING_GRAY_CASE_EVIDENCE"],
        "message": "灰区对象缺少关键补充材料，需先补证"
      },
      "source": {
        "source_type": "system_rule",
        "title": "灰区补证规则",
        "issuer": null,
        "document_no": null,
        "article": null,
        "section": null,
        "chapter": null,
        "clause_label": null,
        "public_access": false,
        "display_name": "灰区补证规则"
      },
      "is_active": true
    },

    {
      "rule_id": "GRAY_003",
      "name": "弱灰区仍属物业维保范围",
      "stage": "GRAY_CASE_REVIEW_CHECK",
      "priority": 52,
      "when": {
        "all": [
          { "field": "normalized_tags", "op": "contains", "value": "gray_case" },
          { "field": "gray_case_type", "op": "eq", "value": "weak" },
          { "field": "gray_case_evidence_complete", "op": "eq", "value": true },
          { "field": "is_property_service_scope", "op": "eq", "value": true }
        ]
      },
      "then": {
        "result": "non_compliant",
        "reason_codes": ["PROPERTY_SERVICE_SCOPE"],
        "message": "补充材料显示项目疑似属于物业服务维保范围"
      },
      "source": {
        "source_type": "public_standard",
        "title": "住宅物业管理服务规范",
        "issuer": "上海市市场监督管理局",
        "document_no": "DB31/T 360—2020",
        "article": null,
        "section": "第9章",
        "chapter": null,
        "clause_label": null,
        "public_access": true,
        "display_name": "《住宅物业管理服务规范》（DB31/T 360—2020）第9章"
      },
      "is_active": true
    },

    {
      "rule_id": "GRAY_004",
      "name": "弱灰区转入正常流程",
      "stage": "GRAY_CASE_REVIEW_CHECK",
      "priority": 53,
      "when": {
        "all": [
          { "field": "normalized_tags", "op": "contains", "value": "gray_case" },
          { "field": "gray_case_type", "op": "eq", "value": "weak" },
          { "field": "gray_case_evidence_complete", "op": "eq", "value": true },
          { "field": "is_property_service_scope", "op": "eq", "value": false },
          { "field": "is_common_part", "op": "eq", "value": true }
        ]
      },
      "then": {
        "result": "continue",
        "route_to": "NORMAL_SCOPE_CHECK",
        "reason_codes": [],
        "message": "弱灰区补证充分，转入正常审计流程"
      },
      "source": {
        "source_type": "system_rule",
        "title": "灰区转正常流程规则",
        "issuer": null,
        "document_no": null,
        "article": null,
        "section": null,
        "chapter": null,
        "clause_label": null,
        "public_access": false,
        "display_name": "灰区转正常流程规则"
      },
      "is_active": true
    },

    {
      "rule_id": "EMG_001",
      "name": "紧急维修缺证明材料",
      "stage": "EMERGENCY_CHECK",
      "priority": 60,
      "when": {
        "all": [
          { "field": "is_emergency", "op": "eq", "value": true },
          {
            "any": [
              { "field": "has_rectification_notice", "op": "eq", "value": false },
              { "field": "has_site_photos", "op": "eq", "value": false },
              { "field": "has_construction_plan", "op": "eq", "value": false }
            ]
          }
        ]
      },
      "then": {
        "result": "need_supplement",
        "reason_codes": ["MISSING_EMERGENCY_DOC"],
        "message": "紧急维修缺少必要证明材料"
      },
      "source": {
        "source_type": "public_notice",
        "title": "黄浦区住宅小区紧急情况下使用维修流程图",
        "issuer": "黄浦区相关房管机构流程指引",
        "document_no": null,
        "article": null,
        "section": "紧急维修备案与支取阶段",
        "chapter": null,
        "clause_label": null,
        "public_access": true,
        "display_name": "黄浦区住宅小区紧急情况下使用维修流程图"
      },
      "is_active": true
    },

    {
      "rule_id": "NORMAL_001",
      "name": "金额达到审价门槛但缺审价材料",
      "stage": "PROCESS_CHECK",
      "priority": 70,
      "when": {
        "all": [
          { "field": "amount", "op": "gte", "value": 50000 },
          { "field": "has_budget_review", "op": "eq", "value": false }
        ]
      },
      "then": {
        "result": "need_supplement",
        "reason_codes": ["MISSING_BUDGET_REVIEW"],
        "message": "金额达到审价门槛，需补充审价材料"
      },
      "source": {
        "source_type": "public_policy",
        "title": "维修资金和公共收益管理基本制度",
        "issuer": "上海市物业相关公开政策解读",
        "document_no": null,
        "article": null,
        "section": "审价制度",
        "chapter": null,
        "clause_label": null,
        "public_access": true,
        "display_name": "维修资金和公共收益管理基本制度—审价制度"
      },
      "is_active": true
    },

    {
      "rule_id": "NORMAL_002",
      "name": "缺表决",
      "stage": "PROCESS_CHECK",
      "priority": 71,
      "when": {
        "all": [
          { "field": "normalized_tags", "op": "contains", "value": "repairable_object" },
          { "field": "has_vote", "op": "eq", "value": false }
        ]
      },
      "then": {
        "result": "need_supplement",
        "reason_codes": ["MISSING_VOTE"],
        "message": "缺少业主表决信息"
      },
      "source": {
        "source_type": "public_regulation",
        "title": "住宅专项维修资金管理办法",
        "issuer": "中华人民共和国建设部、中华人民共和国财政部",
        "document_no": "第165号",
        "article": "第二十二条",
        "section": null,
        "chapter": null,
        "clause_label": null,
        "public_access": true,
        "display_name": "《住宅专项维修资金管理办法》（第165号）第二十二条"
      },
      "is_active": true
    },

    {
      "rule_id": "NORMAL_003",
      "name": "缺公示",
      "stage": "PROCESS_CHECK",
      "priority": 72,
      "when": {
        "all": [
          { "field": "normalized_tags", "op": "contains", "value": "repairable_object" },
          { "field": "has_announcement", "op": "eq", "value": false }
        ]
      },
      "then": {
        "result": "need_supplement",
        "reason_codes": ["MISSING_ANNOUNCEMENT"],
        "message": "缺少公示信息"
      },
      "source": {
        "source_type": "public_policy",
        "title": "维修资金和公共收益管理基本制度",
        "issuer": "上海市物业相关公开政策解读",
        "document_no": null,
        "article": null,
        "section": "公示制度",
        "chapter": null,
        "clause_label": null,
        "public_access": true,
        "display_name": "维修资金和公共收益管理基本制度—公示制度"
      },
      "is_active": true
    }
  ]
}